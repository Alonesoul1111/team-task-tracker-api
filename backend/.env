# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/task_tracker?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=super-secret-access-key-change-in-production-2024
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-2024
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
